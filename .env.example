APP_NAME=AIoT智慧康养健康监测系统
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///data/app.db
REDIS_URL=redis://localhost:6379/0
CHROMA_PATH=./data/chroma

QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_RERANK_MODEL=qwen-reranker-v1
QWEN_RERANK_API=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
QWEN_ENABLE_RERANK=true

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

LLM_TIMEOUT_SECONDS=10
RAG_TIMEOUT_SECONDS=15
RAG_TOP_K=3
RAG_FETCH_K=8
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=150

NETWORK_PROBE_URL=https://dashscope.aliyuncs.com
NETWORK_PROBE_TIMEOUT_SECONDS=3
NETWORK_PROBE_CACHE_SECONDS=20

JWT_SECRET=replace-me-in-production
USE_MOCK_DATA=true
